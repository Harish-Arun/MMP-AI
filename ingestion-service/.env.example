# Environment variable template for ingestion-service
# Copy to .env and fill in real values. DO NOT commit .env to source control.

# SFTP connection
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=sftp_user
# Provide one of: password OR key path
SFTP_PASSWORD=
SFTP_KEY_PATH=/path/to/id_rsa
SFTP_REMOTE_DIR=/uploads
SFTP_POLL_INTERVAL_S=30

# S3 / AWS
S3_BUCKET=mmp-ai-documents
S3_KEY_PREFIX=ingest
S3_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mmp_ai

# Retry behaviour
SFTP_MAX_RECONNECT_ATTEMPTS=5
S3_MAX_UPLOAD_RETRIES=5
BACKOFF_BASE=2.0

# File filtering
EXTENSION_ALLOWLIST=[".pdf"]

# Observability
HEALTH_PORT=8080
OTEL_EXPORTER_OTLP_ENDPOINT=
